@model LibraryManagementSystem.ViewModels.Auth.ExternalLoginConfirmationViewModel
@{
    ViewData["Title"] = "Complete Registration";
}

<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Header -->
        <div class="text-center">
            <div class="mx-auto h-16 w-16 bg-green-100 rounded-full flex items-center justify-center">
                <i class="fas fa-check-circle text-green-600 text-3xl"></i>
            </div>
            <h2 class="mt-6 text-3xl font-bold text-gray-900">Almost There!</h2>
            <p class="mt-2 text-sm text-gray-600">Confirm your details to complete registration</p>
        </div>

        <!-- Form -->
        <div class="bg-white shadow-lg rounded-lg p-8">
            <form asp-action="ExternalLoginConfirmation" method="post" class="space-y-6">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

                <div>
                    <label asp-for="FullName" class="block text-sm font-medium text-gray-700">
                        <i class="fas fa-user mr-1 text-gray-400"></i> Full Name
                    </label>
                    <input asp-for="FullName" type="text" 
                           class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500" />
                    <span asp-validation-for="FullName" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700">
                        <i class="fas fa-envelope mr-1 text-gray-400"></i> Email Address
                    </label>
                    <input asp-for="Email" type="email" 
                           class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>

                <!-- Info Alert -->
                <div class="rounded-md bg-blue-50 p-4">
                    <div class="flex">
                        <i class="fas fa-info-circle text-blue-400 mr-3 mt-0.5"></i>
                        <p class="text-sm text-blue-700">
                            By completing registration, your library account will be linked to your social media profile.
                        </p>
                    </div>
                </div>

                <button type="submit" 
                        class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition">
                    <i class="fas fa-check-circle mr-2"></i> Complete Registration
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}